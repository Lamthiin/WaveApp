<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:background="?attr/selectableItemBackground">

    <TextView
        android:id="@+id/tvSongIndex"
        android:layout_width="20dp"
        android:layout_height="wrap_content"
        android:text="1"
        android:textColor="#B3B3B3"
        android:textSize="13sp" />

    <ImageView
        android:id="@+id/ivSongThumbnail"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_marginStart="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/sontung"
        android:contentDescription="Song Thumbnail" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvSongTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hãy Trao Cho Anh"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:ellipsize="end"
            android:singleLine="true" />

        <TextView
            android:id="@+id/tvSongViews"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="64.974.498"
            android:textColor="#B3B3B3"
            android:textSize="12sp"
            android:layout_marginTop="1dp" />

    </LinearLayout>

    <ImageButton
        android:id="@+id/btnSongOptions"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Song options"
        android:padding="2dp"
        android:scaleType="centerInside"
        android:src="@android:drawable/ic_menu_moreoverflow_normal_holo_dark"
        app:tint="#B3B3B3" />

</LinearLayout>
