<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="#181818"
    android:padding="12dp">

    <TextView
        android:id="@+id/tvAdminItemIndex"
        android:layout_width="24dp"
        android:layout_height="56dp"
        android:gravity="center"
        android:textColor="#B3B3B3"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/ivAdminItemImage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/ivAdminItemImage"
        tools:text="1." />

    <ImageView
        android:id="@+id/ivAdminItemImage"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginStart="8dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_logo"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/tvAdminItemIndex"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvAdminItemTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        android:textColor="#FFFFFF"
        android:textSize="17sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/layoutAdminItemActions"
        app:layout_constraintStart_toEndOf="@id/ivAdminItemImage"
        app:layout_constraintTop_toTopOf="@id/ivAdminItemImage"
        tools:text="Tên mục" />

    <TextView
        android:id="@+id/tvAdminItemSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="#1DB954"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/layoutAdminItemActions"
        app:layout_constraintStart_toStartOf="@id/tvAdminItemTitle"
        app:layout_constraintTop_toBottomOf="@id/tvAdminItemTitle"
        tools:text="Thông tin phụ" />

    <TextView
        android:id="@+id/tvAdminItemMeta"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="#B3B3B3"
        android:textSize="12sp"
        app:layout_constraintEnd_toStartOf="@id/layoutAdminItemActions"
        app:layout_constraintStart_toStartOf="@id/tvAdminItemTitle"
        app:layout_constraintTop_toBottomOf="@id/tvAdminItemSubtitle"
        tools:text="Thông tin mô tả" />

    <LinearLayout
        android:id="@+id/layoutAdminItemActions"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnAdminItemMore"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_more_vert"
            app:tint="#FFFFFF" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
