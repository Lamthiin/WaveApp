<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- Header được ghim cố định ở trên cùng -->
    <include
        android:id="@+id/header_layout"
        layout="@layout/layout_home_header" />

    <!-- Nội dung bên dưới có thể cuộn, nằm dưới header -->
    <ScrollView
        android:id="@+id/home_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header_layout"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="0dp"
            android:paddingBottom="16dp">

            <TextView
                style="@style/SectionTitle"
                android:text="Album nổi tiếng" />

            <include layout="@layout/layout_home_albums" />

            <TextView
                style="@style/SectionTitle"
                android:text="Bảng xếp hạng" />

            <include layout="@layout/layout_home_charts" />

            <TextView
                style="@style/SectionTitle"
                android:text="Nghệ sĩ phổ biến" />

            <include layout="@layout/layout_home_artists" />

            <TextView
                style="@style/SectionTitle"
                android:text="Khám phá các thể loại" />

            <include layout="@layout/layout_home_categories" />

        </LinearLayout>
    </ScrollView>

    <!-- Danh sách bài hát khi chọn tab Nhạc (ẩn mặc định) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_all_songs"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header_layout"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="0dp"
        android:paddingBottom="16dp"
        android:visibility="gone" />
</RelativeLayout>