<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:background="?attr/selectableItemBackground"
    android:paddingHorizontal="16dp">

    <!-- Thumbnail bài hát -->
    <ImageView
        android:id="@+id/img_song_thumbnail"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_logo"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Chấm phát (hiển thị khi đang phát) -->
    <ImageView
        android:id="@+id/img_playing_indicator"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/ic_equalizer"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/img_song_thumbnail"
        app:layout_constraintEnd_toEndOf="@id/img_song_thumbnail"
        app:layout_constraintStart_toStartOf="@id/img_song_thumbnail"
        app:layout_constraintTop_toTopOf="@id/img_song_thumbnail"
        app:tint="#1DB954" />

    <!-- Tên bài hát -->
    <TextView
        android:id="@+id/tv_song_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginBottom="2dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Don't Cụ"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/tv_artist_name"
        app:layout_constraintEnd_toStartOf="@id/btn_more"
        app:layout_constraintStart_toEndOf="@id/img_song_thumbnail"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <!-- Tên nghệ sĩ -->
    <TextView
        android:id="@+id/tv_artist_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="RPT Orijinn, Ronboogz"
        android:textColor="#B3B3B3"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_more"
        app:layout_constraintStart_toEndOf="@id/img_song_thumbnail"
        app:layout_constraintTop_toBottomOf="@id/tv_song_title" />

    <!-- Nút more: bao gồm xóa khỏi playlist -->
    <ImageButton
        android:id="@+id/btn_more"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_more_vert"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#B3B3B3" />

</androidx.constraintlayout.widget.ConstraintLayout>