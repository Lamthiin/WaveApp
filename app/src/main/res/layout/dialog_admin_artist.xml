<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_admin_dialog"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tên nghệ sĩ"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etArtistName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_admin_input"
        android:hint="Nhập tên nghệ sĩ"
        android:inputType="textCapWords"
        android:maxLines="1"
        android:minHeight="52dp"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp"
        android:textColor="#FFFFFF"
        android:textColorHint="#7E7E7E" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="Ảnh đại diện"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivArtistPreview"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_admin_input"
        android:contentDescription="Ảnh nghệ sĩ"
        android:padding="10dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_logo"
        app:shapeAppearanceOverlay="@style/RoundedImageView" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnChooseArtistImage"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:layout_marginTop="10dp"
        android:minWidth="0dp"
        android:text="Chọn ảnh từ máy"
        android:textAllCaps="false"
        android:textColor="#121212"
        app:backgroundTint="#1DB954"
        app:cornerRadius="22dp"
        app:icon="@drawable/ic_add"
        app:iconGravity="textStart"
        app:iconTint="#121212" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="Mô tả nghệ sĩ"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etArtistBio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_admin_input"
        android:gravity="top|start"
        android:hint="Nhập mô tả ngắn"
        android:inputType="textMultiLine"
        android:minHeight="120dp"
        android:minLines="4"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp"
        android:textColor="#FFFFFF"
        android:textColorHint="#7E7E7E" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelArtistDialog"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:minWidth="0dp"
            android:text="Hủy"
            android:textAllCaps="false"
            android:textColor="#B3B3B3"
            app:backgroundTint="@android:color/transparent"
            app:cornerRadius="22dp"
            app:strokeColor="#383838"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveArtistDialog"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            android:minWidth="0dp"
            android:text="Lưu"
            android:textAllCaps="false"
            android:textColor="#121212"
            app:backgroundTint="#1DB954"
            app:cornerRadius="22dp" />
    </LinearLayout>

</LinearLayout>
