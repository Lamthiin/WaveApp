<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_admin_dialog"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvUserRoleDialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cập nhật quyền"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvUserRoleDialogSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Chọn quyền cho người dùng"
        android:textColor="#B3B3B3"
        android:textSize="15sp" />

    <RadioGroup
        android:id="@+id/radioGroupUserRole"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp">

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/radioUserRoleUser"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_admin_input"
            android:buttonTint="#1DB954"
            android:paddingStart="14dp"
            android:paddingTop="14dp"
            android:paddingEnd="14dp"
            android:paddingBottom="14dp"
            android:text="USER"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/radioUserRoleAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_admin_input"
            android:buttonTint="#1DB954"
            android:paddingStart="14dp"
            android:paddingTop="14dp"
            android:paddingEnd="14dp"
            android:paddingBottom="14dp"
            android:text="ADMIN"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />
    </RadioGroup>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelUserRoleDialog"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:minWidth="0dp"
            android:text="Hủy"
            android:textAllCaps="false"
            android:textColor="#B3B3B3"
            app:backgroundTint="@android:color/transparent"
            app:cornerRadius="22dp"
            app:strokeColor="#383838"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveUserRoleDialog"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            android:minWidth="0dp"
            android:text="Lưu"
            android:textAllCaps="false"
            android:textColor="#121212"
            app:backgroundTint="#1DB954"
            app:cornerRadius="22dp" />
    </LinearLayout>

</LinearLayout>
