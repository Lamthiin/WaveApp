<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:maxHeight="560dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_admin_dialog"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tên album"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etAlbumName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_admin_input"
            android:hint="Nhập tên album"
            android:inputType="textCapWords"
            android:maxLines="1"
            android:minHeight="52dp"
            android:paddingStart="16dp"
            android:paddingTop="14dp"
            android:paddingEnd="16dp"
            android:paddingBottom="14dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#7E7E7E" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Nghệ sĩ của album"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <com.google.android.material.textfield.MaterialAutoCompleteTextView
            android:id="@+id/actAlbumArtist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_admin_input"
            android:completionThreshold="0"
            android:dropDownHeight="240dp"
            android:dropDownVerticalOffset="8dp"
            android:hint="Chọn nghệ sĩ"
            android:imeOptions="actionDone"
            android:inputType="textCapWords"
            android:maxLines="1"
            android:minHeight="52dp"
            android:paddingStart="16dp"
            android:paddingTop="14dp"
            android:paddingEnd="16dp"
            android:paddingBottom="14dp"
            android:popupBackground="#282828"
            android:textColor="#FFFFFF"
            android:textColorHint="#7E7E7E" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Ngày phát hành"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etAlbumReleaseDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_admin_input"
            android:hint="yyyy-MM-dd"
            android:inputType="date"
            android:maxLines="1"
            android:minHeight="52dp"
            android:paddingStart="16dp"
            android:paddingTop="14dp"
            android:paddingEnd="16dp"
            android:paddingBottom="14dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#7E7E7E" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Ảnh bìa album"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivAlbumPreview"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_admin_input"
            android:contentDescription="Ảnh bìa album"
            android:padding="10dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_logo"
            app:shapeAppearanceOverlay="@style/RoundedImageView" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnChooseAlbumImage"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginTop="10dp"
            android:minWidth="0dp"
            android:text="Chọn ảnh từ máy"
            android:textAllCaps="false"
            android:textColor="#121212"
            app:backgroundTint="#1DB954"
            app:cornerRadius="22dp"
            app:icon="@drawable/ic_add"
            app:iconGravity="textStart"
            app:iconTint="#121212" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Bài hát trong album"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnChooseAlbumSongs"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:minWidth="0dp"
            android:text="Chọn bài hát"
            android:textAllCaps="false"
            android:textColor="#121212"
            app:backgroundTint="#1DB954"
            app:cornerRadius="22dp"
            app:icon="@drawable/ic_add"
            app:iconGravity="textStart"
            app:iconTint="#121212" />

        <TextView
            android:id="@+id/tvSelectedAlbumSongs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Chưa chọn bài hát nào cho album."
            android:textColor="#B3B3B3"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="end"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelAlbumDialog"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:minWidth="0dp"
                android:text="Hủy"
                android:textAllCaps="false"
                android:textColor="#B3B3B3"
                app:backgroundTint="@android:color/transparent"
                app:cornerRadius="22dp"
                app:strokeColor="#383838"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveAlbumDialog"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginStart="12dp"
                android:minWidth="0dp"
                android:text="Lưu"
                android:textAllCaps="false"
                android:textColor="#121212"
                app:backgroundTint="#1DB954"
                app:cornerRadius="22dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
