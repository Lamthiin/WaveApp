<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/black_bg"
    android:padding="8dp">

    <!-- Album Art -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivNotificationArt"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_centerVertical="true"
        android:scaleType="centerCrop"
        android:src="@drawable/sontung"
        app:shapeAppearanceOverlay="@style/RoundedImageView" />

    <!-- Text Info -->
    <LinearLayout
        android:id="@+id/layoutNotificationText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_marginStart="12dp"
        android:layout_toEndOf="@id/ivNotificationArt"
        android:layout_toStartOf="@id/layoutNotificationControls"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvNotificationTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:singleLine="true"
            android:text="Hãy Trao Cho Anh"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvNotificationArtist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:singleLine="true"
            android:text="Sơn Tùng M-TP"
            android:textColor="@color/gray_text"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Controls -->
    <LinearLayout
        android:id="@+id/layoutNotificationControls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnNotificationPrev"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_media_previous"
            app:tint="@color/white" />

        <ImageButton
            android:id="@+id/btnNotificationPlay"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_media_play"
            app:tint="@color/white" />

        <ImageButton
            android:id="@+id/btnNotificationNext"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_media_next"
            app:tint="@color/white" />

        <ImageButton
            android:id="@+id/btnNotificationRepeat"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_shuffle"
            app:tint="@color/white" />
    </LinearLayout>

    <!-- Progress Bar (Static) -->
    <ProgressBar
        android:id="@+id/notificationProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_below="@id/ivNotificationArt"
        android:layout_marginTop="8dp"
        android:progress="40"
        android:progressTint="@color/spotify_green" />

</RelativeLayout>