<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_admin_dialog"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Đăng xuất"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Bạn có chắc chắn muốn đăng xuất khỏi tài khoản admin không?"
        android:textColor="#B3B3B3"
        android:textSize="15sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelLogoutDialog"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:minWidth="0dp"
            android:text="Hủy"
            android:textAllCaps="false"
            android:textColor="#B3B3B3"
            app:backgroundTint="@android:color/transparent"
            app:cornerRadius="22dp"
            app:strokeColor="#383838"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmLogoutDialog"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            android:minWidth="0dp"
            android:text="Đăng xuất"
            android:textAllCaps="false"
            android:textColor="#121212"
            app:backgroundTint="#1DB954"
            app:cornerRadius="22dp" />
    </LinearLayout>

</LinearLayout>
