<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base dark background -->
    <item>
        <shape>
            <solid android:color="#0B0B0D" />
        </shape>
    </item>

    <!-- Brown to black vertical gradient -->
    <item>
        <shape>
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#8A4B2A"
                android:centerColor="#121212"
                android:endColor="#0B0B0D" />
        </shape>
    </item>

</layer-list>